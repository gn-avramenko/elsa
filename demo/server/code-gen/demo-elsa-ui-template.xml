<?xml version="1.0" encoding="UTF-8"?>
<ui-template xmlns="http://gridnine.com/elsa/meta-ui-template">
    <widget id="text-box-widget" ts-class-name="TextBoxWidget">
        <properties>
            <attribute type="BOOLEAN" name="notEditable"/>
        </properties>
        <model type="STRING"/>
        <configuration type="ENTITY" class-name="com.gridnine.elsa.demo.server.ui.template.TextBoxWidgetConfiguration">
            <property type="BOOLEAN" id="notEditable"/>
        </configuration>
        <validation type="STRING"/>
    </widget>
    <widget id="big-decimal-box-widget" ts-class-name="BigDecimalBoxWidget">
        <properties>
            <attribute type="BOOLEAN" name="notEditable"/>
            <attribute type="INT" name="precision"/>
        </properties>
        <model type="BIG_DECIMAL"/>
        <configuration type="ENTITY"
                       class-name="com.gridnine.elsa.demo.server.ui.template.BigDecimalBoxWidgetConfiguration">
            <property type="BOOLEAN" id="notEditable"/>
        </configuration>
        <validation type="STRING"/>
    </widget>
    <group id="simple-widget">
        <element-ref ref="text-box-widget"/>
        <element-ref ref="big-decimal-box-widget"/>
        <element-ref ref="table"/>
    </group>
    <group id="container">
        <element-ref ref="grid-container"/>
        <element-ref ref="navigator"/>
        <element-ref ref="tile-space"/>
    </group>
    <enum id="com.gridnine.elsa.demo.server.ui.template.GridColumnWidth">
        <enum-item id="STANDARD"/>
        <enum-item id="REMAINING"/>
        <enum-item id="CUSTOM"/>
    </enum>
    <enum id="com.gridnine.elsa.demo.server.ui.template.GridRowHeight">
        <enum-item id="STANDARD"/>
        <enum-item id="REMAINING"/>
        <enum-item id="CUSTOM"/>
    </enum>
    <view-template id="grid-container" ts-class-name="GridContainer">
        <properties>
            <attribute name="columns-count" type="INT" default="1"/>
        </properties>
        <content>
            <property tag-name="columns" type="ENTITY">
                <collection element-tag-name="column" element-type="ENTITY">
                    <attribute name="width" type="ENUM"
                               class-name="com.gridnine.elsa.demo.server.ui.template.GridColumnWidth"
                               default="STANDARD"/>
                    <attribute name="custom-width" type="STRING"/>
                </collection>
            </property>
            <collection element-tag-name="row" element-type="ENTITY">
                <attribute name="height" type="ENUM"
                           class-name="com.gridnine.elsa.demo.server.ui.template.GridRowHeight" default="STANDARD"/>
                <attribute name="custom-height" type="STRING"/>
                <collection element-tag-name="cell" element-type="ENTITY">
                    <group-ref ref="simple-widget"/>
                    <attribute name="col-span" type="INT" default="1"/>
                    <attribute name="caption" type="STRING"/>
                    <attribute name="id" type="STRING" non-nullable="true"/>
                    <attribute name="container-ref" type="STRING"/>
                </collection>
            </collection>
        </content>
    </view-template>
    <view-template id="navigator" ts-class-name="Navigator">
        <content>
            <collection element-tag-name="variant" element-type="ENTITY">
                <attribute name="container-ref" type="STRING"/>
                <group-ref ref="container"/>
            </collection>
        </content>
    </view-template>
    <view-template id="table" ts-class-name="TableEditor">
        <properties>
            <attribute name="notEditable" type="BOOLEAN"/>
        </properties>
        <content>
            <collection element-tag-name="column" element-type="ENTITY">
                <attribute name="caption" type="STRING" non-nullable="true"/>
                <attribute name="pref-width" type="STRING"/>
                <attribute name="id" type="STRING" non-nullable="true"/>
                <group-ref ref="simple-widget"/>
            </collection>
        </content>
    </view-template>
    <view-template id="tile-space" ts-class-name="TileSpace">
        <content>
            <property tag-name="overview" type="ENTITY">
                <attribute name="caption" type="STRING"/>
                <attribute name="container-ref" type="STRING"/>
                <group-ref ref="container"/>
            </property>
            <collection element-tag-name="tile" element-type="ENTITY">
                <attribute name="id" type="STRING" non-nullable="true"/>
                <attribute name="caption" type="STRING" non-nullable="true"/>
                <attribute name="container-ref" type="STRING"/>
                <group-ref ref="container"/>
            </collection>
        </content>
    </view-template>
</ui-template>